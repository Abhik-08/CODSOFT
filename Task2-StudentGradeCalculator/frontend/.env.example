# =============================================================
#  GradeIQ Frontend — Environment Variables Reference
#  Copy this file to .env.development or .env.production
#  and fill in the values. Never commit secrets to source control.
# =============================================================

# Backend API base URL (no trailing slash).
# • Development: leave empty — Vite dev proxy handles /api → localhost:8080
# • Production:  set to your deployed backend, e.g. https://api.gradeiq.com
VITE_API_URL=

# Application display name
VITE_APP_NAME=GradeIQ

# Environment label (development | staging | production)
VITE_APP_ENV=development

# Network request timeout in milliseconds
VITE_API_TIMEOUT_MS=15000
